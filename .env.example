# Required in production
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=kaydet.link,www.kaydet.link
CSRF_TRUSTED_ORIGINS=https://kaydet.link,https://www.kaydet.link

# Site
SITE_NAME=kaydet.link
LANGUAGE_CODE=tr
TIME_ZONE=Europe/Istanbul

# Database (SQLite by default, set for PostgreSQL)
# DATABASE_URL=postgres://user:pass@localhost:5432/kaydetlink

# Email (console backend by default)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@kaydet.link

# SSL (disable if behind a reverse proxy that handles SSL)
# SECURE_SSL_REDIRECT=False
